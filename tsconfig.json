{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    // ─── Added for @ alias imports ─────────────────────────
    "baseUrl": "src",
    "paths": {
      "@Assets/*": ["Assets/*"],
      "@Auth/*": ["auth/*"],
      "@Components/*": ["Components/*"],
      "@Core/*": ["core/*"],
      "@Config/*": ["core/config/*"],
      "@Pages/*": ["Pages/*"],
      "@CSS/*": ["CSS/*"],
      "@Store/*": ["store/*"],
      "@Shared/*": ["shared/*"],
      "@Utilities/*": ["Utilities/*"]
    }
  },
  "include": ["src"]
}
